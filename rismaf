function renderPengumuman(){
const c=document.getElementById('pengumuman-list');
c.innerHTML=pengumuman.map(p=>`
<div class="bg-white rounded-2xl shadow-md p-5 card-hover border border-gray-100">
<div class="flex items-start justify-between gap-3">
<div class="flex-1">
<span class="inline-block text-[10px] font-bold px-2 py-0.5 rounded-full ${colorMap[p.color]} mb-2">${p.tag}</span>
<h3 class="font-extrabold text-gray-800 text-sm">${p.title}</h3>
<p class="text-[10px] text-gray-400 mt-0.5">${p.date}</p>
<p class="text-xs text-gray-600 mt-2">${p.summary}</p>
</div>
<button onclick="openModal(${p.id})" class="shrink-0 bg-emerald1 hover:bg-emerald2 text-white text-[10px] font-bold px-3 py-1.5 rounded-full transition mt-1">Detail</button>
</div>
</div>
`).join('');
}

function openModal(id){
const p=pengumuman.find(x=>x.id===id);if(!p)return;
document.getElementById('modal-title').textContent=p.title;
document.getElementById('modal-date').textContent=p.date;
document.getElementById('modal-body').innerHTML=p.detail;
document.getElementById('modal').classList.add('active');
}
function closeModal(){document.getElementById('modal').classList.remove('active')}

